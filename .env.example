# ─────────────────────────────────────────────────────────────
# ClinCollab Environment Variables — All Modules M1–M6
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase (M1–M6) ──────────────────────────────────────────
# Get from: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://obefnptwfskhihkibsye.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Google OAuth (M1) ─────────────────────────────────────────
# Get from: Google Cloud Console → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── App URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.clincollab.com
NEXT_PUBLIC_SITE_URL=https://clincollab.com
# Local development override:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Groq AI (M4 chatbot + M5 triage synopsis + M6 synthesis) ──
# Get from: console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── WhatsApp Business Cloud API (M3, M4, M5, M6) ─────────────
# Get from: Meta Business Suite → WhatsApp → API Setup
WHATSAPP_API_TOKEN=your_whatsapp_bearer_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Choose any secret string — used to verify Meta webhook calls
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_secret_here

# ── Module 6 — Synthesis Agent ────────────────────────────────
# Random secret for internal API route authentication.
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=generate_with_openssl_rand_hex_32

# ── Resend Email ──────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@clincollab.com

# ── Admin access (M1) ─────────────────────────────────────────
# Comma-separated Google account emails that receive admin role
ADMIN_EMAIL_WHITELIST=avinash40keshri@gmail.com,clincollab40@gmail.com

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# ─────────────────────────────────────────────────────────────
# DEPLOYMENT CHECKLIST (run in order)
# 1. Run Supabase migrations 001 → 006 in SQL Editor
# 2. Set all env vars in Vercel dashboard
# 3. Configure Google OAuth redirect URI in Google Cloud Console:
#    https://app.clincollab.com/auth/callback
# 4. Register WhatsApp webhook in Meta Business Suite:
#    URL: https://app.clincollab.com/api/webhook/whatsapp
#    Verify token: same as WHATSAPP_WEBHOOK_VERIFY_TOKEN
# 5. Enable Supabase Storage bucket: referral-documents (private)
# ─────────────────────────────────────────────────────────────

# ── Module 7 — Transcription Agent ───────────────────────────
# Groq Whisper is used for audio transcription (same GROQ_API_KEY as M4/M5/M6)
# No additional API keys required for transcription.
# Audio file size limit: 25 MB per recording (Groq Whisper limit)
# Supported formats: WebM, MP4, WAV, MP3, M4A
# Audio is processed in memory — never stored permanently

# Maximum recording duration (enforced in UI) — default 60 minutes
MAX_RECORDING_MINUTES=60

# ── Module 10 — Clinical Content Engine ───────────────────────
# No new API keys required — uses existing GROQ_API_KEY for:
#   - Groq LLaMA 3.3 70B (topic decomposition, extraction, structuring)
#   - Groq web_search tool (medical literature search)
#
# Supabase Storage bucket required (create in Supabase dashboard):
#   Bucket name: content-outputs
#   Type: Private (signed URLs used for download)
#
# Generated files are PPTX and DOCX — stored in content-outputs/{specialist_id}/{request_id}/
# Signed URLs expire after 7 days — regenerate via Download button
